// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  email       String   @unique
  name        String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  portfolios   Portfolio[]
  watchlists   Watchlist[]
  signals      TradingSignal[]
  alerts       Alert[]
  tradeHistory TradeHistory[]
}

model Stock {
  id           String   @id @default(cuid())
  symbol       String   @unique
  name         String
  exchange     String   // NSE or BSE
  sector       String
  currentPrice Float
  previousClose Float
  dayHigh      Float
  dayLow       Float
  volume       BigInt
  marketCap    Float?
  peRatio      Float?
  eps          Float?
  weekHigh52   Float?
  weekLow52    Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Portfolio {
  id        String   @id @default(cuid())
  userId    String
  name      String   @default("My Portfolio")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items PortfolioItem[]
}

model PortfolioItem {
  id           String   @id @default(cuid())
  portfolioId  String
  stockSymbol  String
  quantity     Float
  avgBuyPrice  Float
  currentValue Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  name      String   @default("My Watchlist")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items WatchlistItem[]
}

model WatchlistItem {
  id          String   @id @default(cuid())
  watchlistId String
  stockSymbol String
  addedAt     DateTime @default(now())

  watchlist Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)

  @@unique([watchlistId, stockSymbol])
}

model TradingSignal {
  id              String   @id @default(cuid())
  stockSymbol     String
  signal          String   // BUY, SELL, HOLD
  confidence      Float    // 0-100
  reasoning       String
  technicalScore  Float
  sentimentScore  Float
  macroScore      Float
  targetPrice     Float?
  stopLoss        Float?
  timeframe       String?
  generatedBy     String   @default("GEMINI") // GEMINI, TECHNICAL, ML
  userId          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])
}

model NewsArticle {
  id             String   @id @default(cuid())
  title          String
  url            String
  source         String
  publishedAt    DateTime
  sentiment      String   // BULLISH, BEARISH, NEUTRAL
  sentimentScore Float    // -1 to 1
  stockSymbols   String[] // Array of related stock symbols
  summary        String?
  createdAt      DateTime @default(now())
}

model MacroIndicator {
  id            String   @id @default(cuid())
  name          String
  value         Float
  previousValue Float
  unit          String?
  date          DateTime
  impact        String   // HIGH, MEDIUM, LOW
  description   String
  category      String   // MONETARY, FISCAL, TRADE, MARKET
  createdAt     DateTime @default(now())
}

model Alert {
  id          String   @id @default(cuid())
  userId      String
  stockSymbol String
  condition   String   // ABOVE, BELOW, PERCENT_CHANGE
  targetPrice Float
  isActive    Boolean  @default(true)
  triggered   Boolean  @default(false)
  triggeredAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TradeHistory {
  id          String   @id @default(cuid())
  userId      String
  stockSymbol String
  action      String   // BUY, SELL
  quantity    Float
  price       Float
  total       Float
  notes       String?
  timestamp   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
